local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local tposeActive = false
local renderConnection = nil

-- [UI 构建 - 参考你提供的稳健拖动结构]
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Gemini_TPose_System"
pcall(function() ScreenGui.Parent = CoreGui end)
if not ScreenGui.Parent then ScreenGui.Parent = player:WaitForChild("PlayerGui") end

local btn = Instance.new("TextButton")
btn.Parent = ScreenGui
btn.Size = UDim2.new(0, 200, 0, 60)
btn.Position = UDim2.new(0.5, -100, 0.2, 0)
btn.Text = "R15 T-Pose: OFF"
btn.BackgroundColor3 = Color3.fromRGB(130, 30, 30)
btn.TextColor3 = Color3.new(1, 1, 1)
btn.TextScaled = true
btn.Draggable = true -- 【核心：使用你要求的稳健拖动属性】

-- 停止动画函数
local function stopAnims(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        for _, v in pairs(hum:GetPlayingAnimationTracks()) do v:Stop(0) end
    end
end

-- R15 完美平举核心逻辑
local function applyPose()
    local char = player.Character
    if not char or not tposeActive then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.RigType ~= Enum.HumanoidRigType.R15 then return end

    -- 每帧停止所有动画，确保移动时不晃动
    stopAnims(char)

    -- 强制锁定 R15 关节 Transform 实现 90 度平举
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("Motor6D") then
            if v.Name == "LeftShoulder" then
                v.Transform = CFrame.Angles(0, 0, math.rad(-90))
            elseif v.Name == "RightShoulder" then
                v.Transform = CFrame.Angles(0, 0, math.rad(90))
            elseif v.Name == "LeftHip" or v.Name == "RightHip" then
                v.Transform = CFrame.new(0, 0, 0) -- 腿部垂直，不合并
            elseif v.Name == "LeftElbow" or v.Name == "RightElbow" or v.Name == "LeftKnee" or v.Name == "RightKnee" then
                v.Transform = CFrame.new(0, 0, 0) -- 肢体笔直
            elseif v.Name == "Root" or v.Name == "Waist" or v.Name == "Neck" then
                v.Transform = CFrame.new(0, 0, 0) -- 身体不弯曲
            end
        end
    end
end

-- 开关逻辑
btn.MouseButton1Click:Connect(function()
    tposeActive = not tposeActive
    local char = player.Character
    
    if tposeActive then
        btn.Text = "R15 T-Pose: ON"
        btn.BackgroundColor3 = Color3.fromRGB(30, 130, 30)
        
        if char then
            local anim = char:FindFirstChild("Animate")
            if anim then anim.Disabled = true end
            stopAnims(char)
        end
        
        if renderConnection then renderConnection:Disconnect() end
        renderConnection = RunService.Stepped:Connect(applyPose)
    else
        btn.Text = "R15 T-Pose: OFF"
        btn.BackgroundColor3 = Color3.fromRGB(130, 30, 30)
        
        if renderConnection then renderConnection:Disconnect() end
        if char then
            local anim = char:FindFirstChild("Animate")
            if anim then anim.Disabled = false end
            -- R15 无损恢复，不使用 BreakJoints，不重置人物
        end
    end
end)

-- 人物重生检测
player.CharacterAdded:Connect(function(newChar)
    if tposeActive then
        task.wait(1)
        local anim = newChar:WaitForChild("Animate", 5)
        if anim then anim.Disabled = true end
    end
end)

print("R15 T-Pose finishes loading")
