local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local tposeActive = false
local renderConnection = nil

local function stopAllAnimations(char)
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                track:Stop()
            end
        end
    end
end

local function lockTPose()
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    if humanoid.RigType == Enum.HumanoidRigType.R6 then
        local torso = char:FindFirstChild("Torso")
        if torso then
            if torso:FindFirstChild("Left Shoulder") then torso["Left Shoulder"].Transform = CFrame.Angles(0, 0, math.rad(-90)) end
            if torso:FindFirstChild("Right Shoulder") then torso["Right Shoulder"].Transform = CFrame.Angles(0, 0, math.rad(90)) end
            if torso:FindFirstChild("Left Hip") then torso["Left Hip"].Transform = CFrame.new(0, 0, 0) end
            if torso:FindFirstChild("Right Hip") then torso["Right Hip"].Transform = CFrame.new(0, 0, 0) end
        end
    else
        local parts = {"LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg", "LowerTorso"}
        for _, pName in ipairs(parts) do
            local p = char:FindFirstChild(pName)
            if p then
                local joints = {LeftShoulder = -90, RightShoulder = 90, LeftHip = 0, RightHip = 0, Root = 0}
                for jName, angle in pairs(joints) do
                    local j = p:FindFirstChild(jName)
                    if j then
                        j.Transform = (jName == "LeftShoulder" or jName == "RightShoulder") and CFrame.Angles(0, 0, math.rad(angle)) or CFrame.new(0, 0, 0)
                    end
                end
            end
        end
    end
end

local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
ScreenGui.Name = "TPoseDraggableGui"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 130, 0, 50)
MainFrame.Position = UDim2.new(0, 50, 0.5, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
MainFrame.BorderSizePixel = 2
MainFrame.Active = true

local ToggleBtn = Instance.new("TextButton", MainFrame)
ToggleBtn.Size = UDim2.new(1, -10, 1, -10)
ToggleBtn.Position = UDim2.new(0, 5, 0, 5)
ToggleBtn.Text = "T-Pose: OFF"
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleBtn.TextColor3 = Color3.new(1, 1, 1)
ToggleBtn.Font = Enum.Font.SourceSansBold
ToggleBtn.TextSize = 18

local dragging, dragInput, dragStart, startPos

local function onInputBegan(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        local connection
        connection = input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                connection:Disconnect()
            end
        end)
    end
end

MainFrame.InputBegan:Connect(onInputBegan)
ToggleBtn.InputBegan:Connect(onInputBegan)

local function onInputChanged(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end

MainFrame.InputChanged:Connect(onInputChanged)
ToggleBtn.InputChanged:Connect(onInputChanged)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

ToggleBtn.MouseButton1Click:Connect(function()
    tposeActive = not tposeActive
    local char = player.Character
    if tposeActive then
        ToggleBtn.Text = "T-Pose: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        if char then
            local animate = char:FindFirstChild("Animate")
            if animate then animate.Disabled = true end
            stopAllAnimations(char)
        end
        if renderConnection then renderConnection:Disconnect() end
        renderConnection = RunService.Stepped:Connect(lockTPose)
    else
        ToggleBtn.Text = "T-Pose: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        if renderConnection then renderConnection:Disconnect() end
        if char then
            local animate = char:FindFirstChild("Animate")
            if animate then animate.Disabled = false end
        end
    end
end)

player.CharacterAdded:Connect(function(newChar)
    if tposeActive then
        task.wait(0.5)
        local animate = newChar:WaitForChild("Animate", 3)
        if animate then animate.Disabled = true end
        stopAllAnimations(newChar)
    end
end)
