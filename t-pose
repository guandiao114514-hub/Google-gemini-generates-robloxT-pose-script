-- Due to the use of a translator, the entire line of code becomes Chinese, so it cannot be run

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local tposeActive = false
local renderConnection = nil

-- 创建 UI
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
ScreenGui.Name = "TPoseGui"

-- 主框架 (可拖动容器)
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 130, 0, 50)
MainFrame.Position = UDim2.new(0, 50, 0.5, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 2
MainFrame.Active = true -- 必须设为 true 才能检测输入

-- 切换按钮
local ToggleBtn = Instance.new("TextButton", MainFrame)
ToggleBtn.Size = UDim2.new(1, -10, 1, -10)
ToggleBtn.Position = UDim2.new(0, 5, 0, 5)
ToggleBtn.Text = "T-Pose: OFF"
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleBtn.TextColor3 = Color3.new(1, 1, 1)
ToggleBtn.Font = Enum.Font.SourceSansBold
ToggleBtn.TextSize = 18

-- === 拖动逻辑开始 ===
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)
-- === 拖动逻辑结束 ===

-- 停止动画函数
local function stopAnims(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        for _, v in pairs(hum:GetPlayingAnimationTracks()) do v:Stop(0) end
    end
end

-- T-Pose 核心逻辑 (修复角度和位置)
local function applyPose()
    local char = player.Character
    if not char or not tposeActive then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    if hum.RigType == Enum.HumanoidRigType.R6 then
        -- R6 适配
        local t = char:FindFirstChild("Torso")
        if t then
            if t:FindFirstChild("Left Shoulder") then
                t["Left Shoulder"].Transform = CFrame.Angles(0, 0, math.rad(-90))
            end
            if t:FindFirstChild("Right Shoulder") then
                t["Right Shoulder"].Transform = CFrame.Angles(0, 0, math.rad(90))
            end
            if t:FindFirstChild("Left Hip") then
                t["Left Hip"].Transform = CFrame.new(0, 0, 0)
            end
            if t:FindFirstChild("Right Hip") then
                t["Right Hip"].Transform = CFrame.new(0, 0, 0)
            end
        end
    else
        -- R15 适配 (强制锁定肩膀和髋部)
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("Motor6D") then
                if v.Name == "LeftShoulder" or v.Name == "LeftUpperArm" then
                    v.Transform = CFrame.Angles(0, 0, math.rad(-90))
                elseif v.Name == "RightShoulder" or v.Name == "RightUpperArm" then
                    v.Transform = CFrame.Angles(0, 0, math.rad(90))
                elseif v.Name == "LeftHip" or v.Name == "LeftUpperLeg" then
                    v.Transform = CFrame.new(0, 0, 0)
                elseif v.Name == "RightHip" or v.Name == "RightUpperLeg" then
                    v.Transform = CFrame.new(0, 0, 0)
                elseif v.Name == "Neck" or v.Name == "Waist" or v.Name == "Root" then
                    v.Transform = CFrame.new(0, 0, 0) -- 锁死躯干
                end
            end
        end
    end
end

-- 开关点击事件
ToggleBtn.MouseButton1Click:Connect(function()
    tposeActive = not tposeActive
    local char = player.Character
    
    if tposeActive then
        ToggleBtn.Text = "T-Pose: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        if char then
            local anim = char:FindFirstChild("Animate")
            if anim then anim.Disabled = true end
            stopAnims(char)
        end
        
        if renderConnection then renderConnection:Disconnect() end
        renderConnection = RunService.Stepped:Connect(applyPose)
    else
        ToggleBtn.Text = "T-Pose: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        if renderConnection then renderConnection:Disconnect() end
        if char then
            local anim = char:FindFirstChild("Animate")
            if anim then anim.Disabled = false end
            -- 恢复姿势：由于我们修改的是 Transform，停止写入后，动画脚本会自动接管，无需重置人物
        end
    end
end)

-- 人物重生检测
player.CharacterAdded:Connect(function(newChar)
    if tposeActive then
        task.wait(0.5)
        local anim = newChar:WaitForChild("Animate", 5)
        if anim then anim.Disabled = true end
        stopAnims(newChar)
    end
end)

print("T-Pose 脚本已加载，UI 可自由拖动。")
