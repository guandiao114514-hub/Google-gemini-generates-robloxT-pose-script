local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local tposeActive = false
local renderConnection = nil

-- 强制停止所有正在播放的动画
local function stopAllAnimations(char)
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                track:Stop()
            end
        end
        for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
            track:Stop()
        end
    end
end

-- 每帧强制锁定关节 (使用 Transform 以保证 FE 同步)
local function lockTPose()
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    if humanoid.RigType == Enum.HumanoidRigType.R6 then
        -- R6 关节处理
        local torso = char:FindFirstChild("Torso")
        if torso then
            local ls = torso:FindFirstChild("Left Shoulder")
            local rs = torso:FindFirstChild("Right Shoulder")
            local lh = torso:FindFirstChild("Left Hip")
            local rh = torso:FindFirstChild("Right Hip")
            
            -- 手臂横向抬起90度，双脚并拢拉直
            if ls then ls.Transform = CFrame.Angles(0, 0, math.rad(-90)) end
            if rs then rs.Transform = CFrame.Angles(0, 0, math.rad(90)) end
            if lh then lh.Transform = CFrame.new(0, 0, 0) end
            if rh then rh.Transform = CFrame.new(0, 0, 0) end
        end
    else
        -- R15 关节处理
        local leftUpperArm = char:FindFirstChild("LeftUpperArm")
        local rightUpperArm = char:FindFirstChild("RightUpperArm")
        local leftUpperLeg = char:FindFirstChild("LeftUpperLeg")
        local rightUpperLeg = char:FindFirstChild("RightUpperLeg")
        local lowerTorso = char:FindFirstChild("LowerTorso")

        -- 手臂横向抬起90度，双腿拉直不弯曲
        if leftUpperArm and leftUpperArm:FindFirstChild("LeftShoulder") then
            leftUpperArm.LeftShoulder.Transform = CFrame.Angles(0, 0, math.rad(-90))
        end
        if rightUpperArm and rightUpperArm:FindFirstChild("RightShoulder") then
            rightUpperArm.RightShoulder.Transform = CFrame.Angles(0, 0, math.rad(90))
        end
        if leftUpperLeg and leftUpperLeg:FindFirstChild("LeftHip") then
            leftUpperLeg.LeftHip.Transform = CFrame.new(0, 0, 0)
        end
        if rightUpperLeg and rightUpperLeg:FindFirstChild("RightHip") then
            rightUpperLeg.RightHip.Transform = CFrame.new(0, 0, 0)
        end
        -- 锁死脊椎防止走路时晃动
        if lowerTorso and lowerTorso:FindFirstChild("Root") then
            lowerTorso.Root.Transform = CFrame.new(0, 0, 0)
        end
    end
end

-- UI 创建
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local ToggleBtn = Instance.new("TextButton", ScreenGui)

ToggleBtn.Size = UDim2.new(0, 120, 0, 40)
ToggleBtn.Position = UDim2.new(0, 20, 0.5, 0)
ToggleBtn.Text = "T-Pose: OFF"
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.Font = Enum.Font.SourceSansBold
ToggleBtn.TextSize = 18

-- 开关逻辑
ToggleBtn.MouseButton1Click:Connect(function()
    tposeActive = not tposeActive
    local char = player.Character

    if tposeActive then
        ToggleBtn.Text = "T-Pose: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        if char then
            -- 1. 禁用自带动画脚本，防止它跟脚本抢夺关节控制权
            local animate = char:FindFirstChild("Animate")
            if animate then animate.Disabled = true end
            -- 2. 停掉当前正在播放的走路/待机动画
            stopAllAnimations(char)
        end
        
        -- 3. 启动高频覆盖
        if renderConnection then renderConnection:Disconnect() end
        renderConnection = RunService.Stepped:Connect(function()
            if tposeActive then lockTPose() end
        end)
    else
        ToggleBtn.Text = "T-Pose: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- 断开循环，停止强制覆盖
        if renderConnection then 
            renderConnection:Disconnect() 
            renderConnection = nil 
        end
        
        -- 恢复正常（不再重置人物）
        if char then
            local animate = char:FindFirstChild("Animate")
            if animate then animate.Disabled = false end
        end
    end
end)

-- 死亡/重置后自动重连功能
player.CharacterAdded:Connect(function(newChar)
    if tposeActive then
        task.wait(0.5) -- 给游戏一点时间加载角色
        local animate = newChar:WaitForChild("Animate", 3)
        if animate then animate.Disabled = true end
        stopAllAnimations(newChar)
    end
end)
